<col align="left" valign="middle" width="33%"/>
<col align="left" valign="middle" width="37%"/>
<thead>
<tr class="First Last">
<th align="center" class="Lrule Rrule">Adverse Reaction</th><th align="center" class="Rrule">Severity<a class="Sup" href="#footnote-5" name="footnote-reference-5">*</a></th><th align="center" class="Rrule">Dosage Modification</th>
</tr>
</thead>
<tfoot>
<tr class="First Last">
<td align="left" colspan="3">ALT = alanine aminotransferase, AST = aspartate aminotransferase, DRESS = Drug Rash with Eosinophilia and Systemic Symptoms, SJS = Stevens Johnson Syndrome, TEN = toxic epidermal necrolysis, ULN = upper limit normal</td>
</tr>
